# ── AI Docker Assistant — environment variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# docker-compose will load .env automatically.

# App
ENV=development
PORT=8000

# Phase 2: set to true after running  python ml/train_recommender.py
USE_ML_MODEL=false

# Phase 3: set to true after running  python ml/train_debugger.py
USE_ML_CLASSIFIER=false
